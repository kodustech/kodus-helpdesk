{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "monorepo": true,
    "compilerOptions": {
        "builder": "webpack",
        "typeCheck": false,
        "plugins": [
            {
                "name": "@nestjs/swagger/plugin",
                "options": {
                    "classValidatorShim": true,
                    "introspectComments": true
                }
            }
        ],
        "deleteOutDir": true,
        "webpack": true,
        "watchAssets": true
    },
    "projects": {
        "api": {
            "type": "application",
            "root": "apps/api",
            "entryFile": "main",
            "sourceRoot": "apps/api/src"
        }
    }
}
