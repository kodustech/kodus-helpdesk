# API
API_PORT=3007
API_NODE_ENV=development

# PostgreSQL (shared kodus_db)
API_PG_DB_HOST=localhost
API_PG_DB_PORT=5432
API_PG_DB_USERNAME=kodus
API_PG_DB_PASSWORD=kodus
API_PG_DB_DATABASE=kodus_db

# JWT - Helpdesk own secret (for self-hosted users)
JWT_SECRET=helpdesk-change-me

# JWT - Kodus AI shared secret (for cloud users SSO)
KODUS_JWT_SECRET=

# Customer.io (email invites)
API_CUSTOMERIO_APP_API_TOKEN=
API_CUSTOMERIO_BASE_URL=https://api.customer.io
HELPDESK_FRONTEND_URL=http://localhost:3004
MAIL_FROM_EMAIL=noreply@kodus.io
MAIL_FROM_NAME=Kodus Helpdesk

# Web
WEB_PORT=3004
WEB_NODE_ENV=development
WEB_HOSTNAME_API=http://localhost:3003
AUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3004

# Docker
RUN_MIGRATIONS=true
RUN_SEEDS=true

# Database port for local docker (avoids conflict with kodus-ai on 5432)
DB_PORT=5433

ALLOWED_PARENT_ORIGINS=http://localhost:3000

# GitHub Integration
GITHUB_TOKEN=
GITHUB_ORG=kodustech
GITHUB_PROJECT_NUMBER=4
GITHUB_REPOSITORY=kodus-ai

# S3 / Storage (use MinIO locally via docker-compose)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_BUCKET_NAME=kodus-helpdesk
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_PUBLIC_ENDPOINT=http://localhost:9000
AWS_S3_FORCE_PATH_STYLE=true