{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": ["ES2022"],
        "declaration": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": ".",
        "skipLibCheck": true,
        "strictNullChecks": false,
        "noImplicitAny": false,
        "incremental": true,
        "resolveJsonModule": true,
        "paths": {
            "@helpdesk/api/*": ["./apps/api/src/*"],
            "@helpdesk/shared/*": ["./libs/shared/*"]
        }
    },
    "watchOptions": {
        "watchFile": "useFsEventsOnParentDirectory"
    }
}
