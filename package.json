{
    "name": "kodus-helpdesk",
    "version": "0.0.1",
    "private": true,
    "license": "UNLICENSED",
    "workspaces": {
        "packages": [
            "apps/*"
        ],
        "nohoist": [
            "**/next",
            "**/next/**",
            "**/react",
            "**/react/**",
            "**/react-dom",
            "**/react-dom/**",
            "**/@tiptap/**",
            "**/tippy.js",
            "**/tippy.js/**",
            "**/@dnd-kit/**"
        ]
    },
    "scripts": {
        "start:dev:all": "concurrently --names api,web --prefix-colors blue,green \"yarn start:dev:api\" \"yarn start:dev:web\"",
        "start:dev:api": "cd apps/api && yarn start:dev",
        "start:dev:web": "cd apps/web && yarn start:dev",
        "build": "yarn build:api && yarn build:web",
        "build:api": "cd apps/api && yarn build",
        "build:web": "cd apps/web && yarn build",
        "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
        "format": "prettier --write \"{apps,libs}/**/*.ts\"",
        "typecheck": "tsc --noEmit",
        "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "migration:generate": "yarn typeorm migration:generate -d apps/api/src/config/database/ormconfig.ts",
        "migration:run": "yarn typeorm migration:run -d apps/api/src/config/database/ormconfig.ts",
        "migration:revert": "yarn typeorm migration:revert -d apps/api/src/config/database/ormconfig.ts",
        "migration:run:internal": "yarn typeorm migration:run -d apps/api/src/config/database/ormconfig.ts",
        "migration:revert:internal": "yarn typeorm migration:revert -d apps/api/src/config/database/ormconfig.ts",
        "seed": "ts-node -r tsconfig-paths/register apps/api/src/config/database/seed/main.seeder.ts",
        "seed:internal": "yarn seed",
        "docker:build": "docker compose -f docker-compose.dev.yml build",
        "docker:start": "docker compose -f docker-compose.dev.yml up -d",
        "docker:stop": "docker compose -f docker-compose.dev.yml down",
        "docker:restart": "docker compose -f docker-compose.dev.yml restart",
        "docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
        "docker:clean": "docker compose -f docker-compose.dev.yml down -v --rmi all",
        "docker:up:infra": "docker compose -f docker-compose.dev.yml --profile local-db up -d",
        "fetch:env:prod": "./scripts/dev/fetch-env-prod.sh prod",
        "fetch:env:qa": "./scripts/dev/fetch-env-qa.sh qa",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "dependencies": {
        "@nestjs/common": "^11.1.16",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.16",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.16",
        "@nestjs/swagger": "^11.2.0",
        "@nestjs/typeorm": "^11.0.0",
        "bcryptjs": "^2.4.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "helmet": "^8.1.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "typeorm": "^0.3.28",
        "uuid": "^13.0.0",
        "axios": "^1.7.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.16",
        "@nestjs/schematics": "^11.0.5",
        "@nestjs/testing": "^11.1.16",
        "@types/bcryptjs": "^2.4.6",
        "@types/express": "^5.0.2",
        "@types/node": "^22.15.0",
        "@types/passport-jwt": "^4.0.1",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.57.0",
        "concurrently": "^9.1.2",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.5",
        "jest": "^30.3.0",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "ts-loader": "^9.5.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3"
    }
}
